	cd /home/sunny/.project/Sunny/.claude/worktrees/agent-a555f056/build && $(MAKE) $(MAKESILENT) -f src/Sunny.Infrastructure/CMakeFiles/Sunny.Infrastructure.dir/build.make src/Sunny.Infrastructure/CMakeFiles/Sunny.Infrastructure.dir/Transport/INTP001A.cpp.i
.PHONY : Transport/INTP001A.cpp.i

Transport/INTP001A.s: Transport/INTP001A.cpp.s
.PHONY : Transport/INTP001A.s

